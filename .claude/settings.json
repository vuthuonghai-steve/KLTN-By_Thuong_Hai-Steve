{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/pre-write-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/orchestrator-write-blocker.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/orchestrator-write-blocker.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/session-end.sh",
            "timeout": 100,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/task-review-prompt.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/subagent-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/steve/Documents/KLTN/.claude/hooks/subagent-stop.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
