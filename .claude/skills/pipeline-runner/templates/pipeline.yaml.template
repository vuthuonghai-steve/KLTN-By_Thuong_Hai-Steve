# {pipeline_name} Pipeline Configuration
# Variables enclosed in {{}} will be resolved at runtime

pipeline:
  name: "{{pipeline_name}}"
  version: "1.0"
  description: "{{pipeline_description}}"

# Input sources for this pipeline
inputs:
  - name: {{input_name_1}}
    path: {{input_path_1}}
    type: {{input_type_1}}
    required: {{required_1}}

# Execution stages in order
stages:
  - id: {{stage_id_1}}
    skill: {{skill_name_1}}
    depends_on: []
    input_sources: [{{input_name_1}}]
    output_path: {{output_path_1}}
    validation:
      script: {{validation_script_1}}
      expected_exit_code: 0
    checkpoint: true
    auto_advance: true

  - id: {{stage_id_2}}
    skill: {{skill_name_2}}
    depends_on: [{{stage_id_1}}]
    input_sources: [{{stage_id_1}}_output]
    output_path: {{output_path_2}}
    validation:
      script: {{validation_script_2}}
      expected_exit_code: 0
    checkpoint: true
    auto_advance: true

# Global settings
settings:
  timeout_per_stage: {{timeout_seconds}}
  max_retries: {{max_retry_count}}
  checkpoint_on_error: true
  human_pause_enabled: {{human_pause_enabled}}
