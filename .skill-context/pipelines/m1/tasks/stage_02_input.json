{
  "module": "M1",
  "module_name": "Authentication & Profile",
  "spec_file": "Docs/life-2/specs/m1-auth-profile-spec.md",
  "flows": [
    {
      "flow_id": "login",
      "description": "User logs in with email/password",
      "actors": ["User", "System", "Database"],
      "interactions": [
        "User enters email/password",
        "System validates credentials",
        "Database verifies user",
        "System returns auth token"
      ]
    },
    {
      "flow_id": "register",
      "description": "User registers - auto-creates profile",
      "actors": ["User", "System", "Database"],
      "interactions": [
        "User submits registration form",
        "System validates input (Zod)",
        "System auto-generates username from email if not provided",
        "Database creates user record",
        "System auto-creates profile group"
      ]
    },
    {
      "flow_id": "profile_update",
      "description": "Update profile information",
      "actors": ["User", "System", "Database"],
      "interactions": [
        "User edits profile fields",
        "System validates (bio max 160, social_links valid URLs)",
        "Database updates user document"
      ]
    }
  ]
}
