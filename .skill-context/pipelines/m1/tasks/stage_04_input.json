{
  "module": "M1",
  "module_name": "Authentication & Profile",
  "spec_file": "Docs/life-2/specs/m1-auth-profile-spec.md",
  "processes": [
    {
      "process_id": "login_process",
      "name": "Login Process",
      "description": "User authentication with email/password",
      "swimlanes": ["User", "System", "Database"],
      "activities": [
        "User enters credentials",
        "Validate email format",
        "Verify password hash",
        "Generate session/token",
        "Return success/failure"
      ],
      "decisions": [
        "Valid credentials?",
        "Account exists?"
      ]
    },
    {
      "process_id": "register_process",
      "name": "Registration Process",
      "description": "New user registration with auto profile creation",
      "swimlanes": ["User", "System", "Database"],
      "activities": [
        "User fills registration form",
        "Validate input (Zod)",
        "Check username availability",
        "Auto-generate username from email if empty",
        "Hash password",
        "Create user document",
        "Initialize empty profile",
        "Send verification email (future)"
      ],
      "decisions": [
        "Username provided?",
        "Username available?",
        "Email valid?"
      ]
    },
    {
      "process_id": "profile_update_process",
      "name": "Profile Update Process",
      "description": "Update user profile information",
      "swimlanes": ["User", "System", "Database"],
      "activities": [
        "User navigates to edit profile",
        "Upload avatar (optional)",
        "Update bio (max 160 chars)",
        "Add/remove social links",
        "Validate URLs",
        "Update document",
        "Return success"
      ],
      "decisions": [
        "Avatar uploaded?",
        "Valid URL format?"
      ]
    }
  ]
}
