{
  "module": "M1",
  "module_name": "Authentication & Profile",
  "spec_file": "Docs/life-2/specs/m1-auth-profile-spec.md",
  "output_file": "Docs/life-2/database/schema-design.md",
  "collections": [
    {
      "name": "users",
      "slug": "users",
      "description": "Main user authentication and profile collection",
      "fields": [
        {
          "name": "email",
          "type": "email",
          "required": true,
          "unique": true,
          "index": true
        },
        {
          "name": "username",
          "type": "text",
          "required": true,
          "unique": true,
          "index": true,
          "validation": "min 3, max 20, regex: ^[a-zA-Z0-9_]+$"
        },
        {
          "name": "password",
          "type": "password",
          "required": true,
          "security": "hash with bcrypt, never expose"
        },
        {
          "name": "roles",
          "type": "select",
          "options": ["admin", "user"],
          "default": "user",
          "hasMany": false
        },
        {
          "name": "profile",
          "type": "group",
          "fields": [
            {
              "name": "display_name",
              "type": "text"
            },
            {
              "name": "avatar",
              "type": "upload",
              "relationTo": "media"
            },
            {
              "name": "bio",
              "type": "textarea",
              "validation": "max 160 characters"
            },
            {
              "name": "social_links",
              "type": "array",
              "fields": [
                {
                  "name": "platform",
                  "type": "select",
                  "options": ["github", "twitter", "linkedin", "website", "other"]
                },
                {
                  "name": "url",
                  "type": "url"
                }
              ]
            }
          ]
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "index": true
        },
        {
          "name": "updatedAt",
          "type": "datetime"
        }
      ],
      "access_control": {
        "read": {
          "condition": "return true"
        },
        "create": {
          "condition": "return true"
        },
        "update": {
          "condition": "if (req.user) return req.user.id === id"
        },
        "delete": {
          "condition": "return req.user?.roles?.includes('admin')"
        }
      },
      "hooks": {
        "beforeChange": [
          "Validate email format",
          "Auto-generate username from email if empty"
        ],
        "afterChange": [
          "Update search index (future)"
        ]
      }
    }
  ]
}
