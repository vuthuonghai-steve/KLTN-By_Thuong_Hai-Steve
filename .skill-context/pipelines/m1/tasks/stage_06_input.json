{
  "module": "M1",
  "module_name": "Authentication & Profile",
  "spec_file": "Docs/life-2/specs/m1-auth-profile-spec.md",
  "output_path": "Docs/life-2/ui/",
  "screens": [
    {
      "screen_id": "LoginScreen",
      "description": "User login form",
      "features": [
        "Email input field",
        "Password input field",
        "Sign in button",
        "Link to Register screen",
        "Google sign-in button (hidden - locked)"
      ],
      "validation": {
        "email": "valid email format",
        "password": "required, min 8 chars"
      }
    },
    {
      "screen_id": "RegisterScreen",
      "description": "User registration form",
      "features": [
        "Username input (optional - auto-generate from email)",
        "Email input field",
        "Password input field",
        "Confirm password input field",
        "Register button",
        "Link to Login screen"
      ],
      "validation": {
        "username": "min 3, max 20, regex: ^[a-zA-Z0-9_]+$",
        "email": "valid email format",
        "password": "min 8 chars",
        "confirm_password": "must match password"
      }
    },
    {
      "screen_id": "ProfileScreen",
      "description": "View user profile",
      "features": [
        "Avatar display",
        "Display name",
        "Username",
        "Bio (max 160 chars)",
        "Social links list",
        "Edit Profile button (owner only)",
        "Follow/Connect button (other users)"
      ]
    },
    {
      "screen_id": "EditProfileScreen",
      "description": "Edit user profile form",
      "features": [
        "Avatar upload/change",
        "Display name input",
        "Bio textarea (max 160 chars)",
        "Social links editor (add/remove)",
        "Save button",
        "Cancel button"
      ],
      "validation": {
        "display_name": "optional",
        "bio": "max 160 characters",
        "social_links": "valid URLs only"
      }
    }
  ],
  "design_system": {
    "name": "Pink Petals",
    "colors": {
      "primary": "Pink-500",
      "secondary": "Orange-500"
    },
    "components": "Radix UI based",
    "style": "Neobrutalism with pink primary"
  }
}
